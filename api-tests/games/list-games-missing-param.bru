meta {
  name: List Games - Missing Player Param Returns 400
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/games
  body: none
  auth: none
}

headers {
  Accept: application/json
}

tests {
  test("returns 400 when player param is missing", function() {
    expect(res.status).to.equal(400);
  });

  test("error message mentions player param", function() {
    expect(res.body.toLowerCase()).to.include('player');
  });
}
